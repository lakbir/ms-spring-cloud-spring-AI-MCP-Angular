# Configuration des variables d'environnement pour l'orchestration Docker
# Copiez ce fichier en .env et remplissez les valeurs appropriées

# ============================
# Configuration API
# ============================

# Clé API pour le service Groq/OpenAI du chatbot
# Récupérez votre clé depuis https://console.groq.com
API_KEY=gsk_votre_cle_api_ici

# ============================
# Configuration des services
# ============================

# Mode d'exécution (optionnel)
SPRING_PROFILES_ACTIVE=docker

# ============================
# Configuration de la mémoire Java (optionnel)
# ============================

# Heap initial et maximum pour les services Java
# Augmentez ces valeurs si les services font des timeouts
JAVA_OPTS=-Xmx512m -Xms256m

# Pour plus de mémoire (si vous avez 16GB+ disponible):
# JAVA_OPTS=-Xmx2g -Xms1g

# ============================
# Configuration des logs (optionnel)
# ============================

# Niveau de log: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Format des logs
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %logger{36} - %msg%n

# ============================
# Configuration des bases de données (optionnel)
# ============================

# H2 Database (utilisée par défaut)
DB_URL=jdbc:h2:mem:customer-db
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=

# ============================
# Configuration Eureka Discovery
# ============================

EUREKA_SERVICE_URL=http://discovery:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true

# ============================
# Configuration du Gateway
# ============================

# URL de base pour les routes du gateway
GATEWAY_BASE_URL=http://gateway:8888

# ============================
# Configuration de développement (optionnel)
# ============================

# Timeout pour les healthchecks (secondes)
HEALTH_CHECK_INTERVAL=10
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# Délai d'attente maximum pour que les services soient prêts (secondes)
STARTUP_TIMEOUT=300

